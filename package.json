{
  "name": "glm-acp-agent",
  "version": "1.0.0",
  "description": "ACP agent in TypeScript that uses the Zhipu AI GLM series (specifically GLM-5.1 and GLM-4.7) as the reasoning core",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "glm-acp-agent": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "keywords": [
    "acp",
    "agent",
    "glm",
    "zhipu",
    "coding-agent"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.20.0",
    "openai": "^6.34.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
